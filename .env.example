# Backend Configuration
BACKEND_PORT=5000
BACKEND_HOST=0.0.0.0

# Frontend Configuration (desarrollo)
REACT_APP_PORT=3000

# URL del API para el frontend
# Desarrollo local: dejar vacío y usar proxy de React (package.json)
# Producción con nginx en mismo dominio: dejar vacío
# Producción con API en otro host: https://tu-dominio.com o http://IP:5000
REACT_APP_API_URL=

# URL pública del frontend (usada en el QR generado)
# Ejemplo producción: https://dynqr.sector7gp.com
# Ejemplo red local: http://10.10.7.10:3099
FRONTEND_PUBLIC_URL=http://localhost:3000

# Orígenes permitidos por CORS (separados por coma)
# Solo necesario si frontend y backend están en dominios/puertos distintos
# CORS_ORIGINS=https://dynqr.sector7gp.com,http://10.10.7.10:3099

# Servir frontend compilado desde Express (RECOMENDADO con Nginx Proxy Manager)
# npm run build && SERVE_FRONTEND=true npm run backend
SERVE_FRONTEND=true

# ── Página del QR (frontend — requieren npm run build) ──
REACT_APP_QR_TITLE=🎬 Escanea para Reservar
REACT_APP_QR_SUBTITLE=¡Bienvenido a Toy Story Universe!
# Mostrar cuadro del contador: true | false
REACT_APP_SHOW_COUNTDOWN=true
