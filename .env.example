# Backend Configuration
# Puerto en el que corre el servidor Express
BACKEND_PORT=5000

# Host del backend (localhost, 127.0.0.1, o tu IP publica)
BACKEND_HOST=localhost

# Frontend Configuration
# Puerto en el que corre React (desarrollo)
REACT_APP_PORT=3000

# URL del API backend (debe coincidir con BACKEND_PORT y BACKEND_HOST)
# Ejemplo si backend está en puerto 8080:
# REACT_APP_API_URL=http://localhost:8080
REACT_APP_API_URL=http://localhost:5000

# Ejemplos de uso:
# Para desarrollo local normal:
#   BACKEND_PORT=5000
#   REACT_APP_PORT=3000
#   REACT_APP_API_URL=http://localhost:5000

# Para puertos personalizados:
#   BACKEND_PORT=8080
#   REACT_APP_PORT=3000
#   REACT_APP_API_URL=http://localhost:8080

# Para múltiples instancias:
# Instancia 1:
#   BACKEND_PORT=5000
#   REACT_APP_PORT=3000
#   REACT_APP_API_URL=http://localhost:5000

# Instancia 2:
#   BACKEND_PORT=5001
#   REACT_APP_PORT=3001
#   REACT_APP_API_URL=http://localhost:5001
